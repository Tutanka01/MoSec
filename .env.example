# ─────────────────────────────────────────────
# MoSec SAST pipeline — environment variables
# Copy to .env and edit before running.
# ─────────────────────────────────────────────

# OpenAI-compatible LLM endpoint (local llama-server)
LLM_BASE_URL=https://llm.eva.univ-pau.fr/v1

# Model identifier as reported by the server
LLM_MODEL=gemma-4-31b-it-q8_0

# API key — leave empty for local endpoints that don't require auth
LLM_API_KEY=
