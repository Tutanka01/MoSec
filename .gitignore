# ─────────────────────────────────────────────────────────────────────────────
# MoSec SAST — .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Secrets & configuration ───────────────────────────────────────────────────
.env
*.env.local
*.env.*.local

# ── Pipeline outputs (never commit audit results) ─────────────────────────────
sast-agent/output/
output/

# Generated intermediate JSON (anywhere in the tree)
manifest.json
findings.json
taint_specs.json
confirmed_flows.json
validated_vulns.json
pipeline_report.json
token_usage.json

# Final reports
results.sarif
report.md
pipeline.log

# ── Semgrep generated rules ───────────────────────────────────────────────────
audit_rules/

# ── CodeQL databases (large, binary, fully reproducible) ──────────────────────
codeql_db/
*.bqrs
*.ql.cache

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environments
venv/
.venv/
env/
.env/
ENV/
.python-version

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
wheels/
MANIFEST

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Tests & coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.tox/
.nox/

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# ── Tree-sitter build artifacts ───────────────────────────────────────────────
parser.c
*.so

# ── Docker local overrides ────────────────────────────────────────────────────
# (docker-compose.yml and Dockerfile are intentionally tracked)
docker-compose.override.yml
docker-compose.local.yml

# ── IDEs ─────────────────────────────────────────────────────────────────────
# VS Code — track shared settings, ignore personal ones
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example

# JetBrains (PyCharm, etc.)
.idea/
*.iml
*.ipr
*.iws

# Vim / Neovim
*.swp
*.swo
*~
Session.vim

# Emacs
\#*\#
.\#*

# Sublime Text
*.sublime-workspace

# ── OS ────────────────────────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.directory

# ── Misc ─────────────────────────────────────────────────────────────────────
*.log
*.bak
*.tmp
*.orig
.cache/
